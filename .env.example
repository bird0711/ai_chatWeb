# AI Chat Groups local configuration example

# HTTP server listen address.
ADDR=:8080

# MySQL connection. If MYSQL_DSN is set, the individual MYSQL_* values are ignored.
MYSQL_USER=root
MYSQL_PASSWORD=4399
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ai_chat
# MYSQL_DSN=root:4399@tcp(127.0.0.1:3306)/ai_chat?parseTime=true&multiStatements=true&charset=utf8mb4,utf8

# Redis connection.
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=4399
REDIS_DB=0

# Optional local asset/template overrides, mainly useful for tests or custom packaging.
TEMPLATE_GLOB=web/templates/*.html
STATIC_DIR=web/static
UPLOAD_DIR=uploads
CHAT_FILE_DIR=data/chat-files

# Optional model API resilience tuning.
MODEL_API_TIMEOUT_SECONDS=90
MODEL_API_TLS_HANDSHAKE_TIMEOUT_SECONDS=30
MODEL_API_RETRY_ATTEMPTS=2
MODEL_API_RETRY_BACKOFF_MS=800
